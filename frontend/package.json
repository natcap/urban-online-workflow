{
    "name": "urban-es-modeler",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "start": "vite",
        "start-docker-prod": "cross-env MODE=docker VITE_URBANONLINE_DEVMODE=false vite --host 0.0.0.0 --port 3000",
        "start-docker-dev": "cross-env MODE=docker VITE_URBANONLINE_DEVMODE=true vite --host 0.0.0.0 --port 3000",
        "build": "vite build",
        "serve": "vite preview",
        "test": "vitest run --dir tests --coverage",
        "test-e2e": "vitest run --dir tests-e2e"
    },
    "dependencies": {
        "@blueprintjs/core": "^5.12.0",
        "@vitejs/plugin-react": "^5.1.4",
        "cross-env": "^10.1.0",
        "dotenv": "^17.2.4",
        "jsts": "^2.12.1",
        "localforage": "^1.10.0",
        "ol": "^6.15.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "vite": "^7.3.1"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.28.6",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@vitest/coverage-v8": "^4.0.18",
        "c8": "^10.1.3",
        "eslint": "^10.0.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "happy-dom": "^20.6.1",
        "jsdom": "^28.0.0",
        "puppeteer": "^24.37.2",
        "vitest": "^4.0.18"
    }
}
